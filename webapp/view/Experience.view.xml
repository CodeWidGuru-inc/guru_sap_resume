    <l:ResponsiveSplitter defaultPane="default">
        <l:PaneContainer>
            <l:SplitPane requiredParentWidth="600"
                         id="default">
                <Panel id="exp_panel"
                       headerText=""
                       stickyHeader="true"
                       width="auto"
                       class="sapUiResponsiveMargin"
                       expand="true">
                    <ScrollContainer height="44vh"
                                     width="auto"
                                     vertical="true"
                                     horizontal="false"
                                     class="sapUiContentPadding">
                        <f:GridList id="ExperienceList"
                                    items="{Experience>/}">
                            <f:customLayout>
                                <cssgrid:GridBoxLayout xmlns:cssgrid="sap.ui.layout.cssgrid" 
                                                       boxesPerRowConfig="XL1 L1 M1 S1" />
                            </f:customLayout>
                            <f:GridListItem type="Active"
                                            press="onPress">
                                <VBox class="sapUiSmallMargin">
                                    <FlexBox justifyContent="Center" alignItems="Center"
                                             direction="Row" renderType="Div">
                                        <VBox width="100%">
                                            <layoutData>
                                            <FlexItemData growFactor="1" />
                                            </layoutData>

                                            <Image class="logo"
                                                   src="{Experience>logo}" />
                                        </VBox>
                                        <VBox width="100%" justifyContent="Center" alignItems="Start">
                                            <layoutData>
                                            <FlexItemData growFactor="2" />
                                            </layoutData>

                                            <Title text="{Experience>company}"
                                                   wrapping="true" />
                                            <Label class="clientText" text="Client - {Experience>client}"
                                                   wrapping="true" />
                                            <Label class="roleText" text="Role - {Experience>role}"
                                                   wrapping="true" />
                                            <Label text="{Experience>duration}"
                                                   wrapping="true" />
                                            <Label text=""
                                                   width="100%" />
                                        </VBox>
                                        <VBox width="100%">
                                            <layoutData>
                                            <FlexItemData growFactor="1"/>
                                            </layoutData>
                                            <Image class="clientlogo"
                                               src="{Experience>logo_client}" />
                                        </VBox>       
                                    </FlexBox>
                                    <HBox>
                                        <tnt:InfoLabel text="Project Description - " />
                                        <Text class="textJustify"
                                              text="{Experience>Project Description}"
                                              wrapping="true"
                                              wrappingType="Hyphenated" />
                                    </HBox>
                                </VBox>
                            </f:GridListItem>
                        </f:GridList>
                    </ScrollContainer>
                </Panel>
            </l:SplitPane>
            <l:PaneContainer orientation="Vertical">
                <l:SplitPane requiredParentWidth="600">
                    <l:layoutData>
                        <l:SplitterLayoutData size="auto"/>
                    </l:layoutData>
                    <Panel stickyHeader="true"
                           headerText="Experience Details"
                           width="auto"
                           class="sapUiResponsiveMargin">
                        <VBox items="{detailsModel>/}"
                              id="fillme"
                              height="40vh"
                              width="auto"
                              class="sapUiSmallMargin">
                            <items>
                                <VBox>
                                    <!-- Main bullet -->
                                    <Text class="bulletPoint"
                                          text="{= Array.isArray(${detailsModel>}) ? '' : '• ' + ${detailsModel>}}"
                                          wrapping="true" />
                                    <!-- <Text text="{detailsModel>details}" wrapping="true"></Text> -->
                                    <!-- Sub-bullets if it's an array -->
                                    <VBox visible="{= Array.isArray(${detailsModel>}) }"
                                          items="{detailsModel>}">
                                        <items>
                                            <Text class="subBulletPoint"
                                                  text="◦ {detailsModel>}"
                                                  wrapping="true"
                                                  renderWhitespace="true"
                                                  textAlign="Initial"
                                                  wrappingType="Hyphenated" />
                                        </items>
                                    </VBox>
                                </VBox>
                            </items>
                        </VBox>
                    </Panel>
                </l:SplitPane>
            </l:PaneContainer>
        </l:PaneContainer>
    </l:ResponsiveSplitter>
</mvc:View>