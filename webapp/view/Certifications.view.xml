<?xml version="1.0" encoding="UTF-8"?>
<mvc:View xmlns:core="sap.ui.core"
          xmlns:f="sap.f"
          controllerName="SapDevPortfolio.controller.Certifications"
          xmlns:mvc="sap.ui.core.mvc"
          xmlns:html="sap.ui.core.HTML"
          xmlns:l="sap.ui.layout"
          xmlns:grid="sap.ui.layout.cssgrid"
          xmlns="sap.m">
    <Panel id="CertificationsList"
           backgroundDesign="Transparent">
        <f:GridList id="CertificationsGridList"
                    items="{Certifications>/}">
            <f:customLayout>
                <grid:ResponsiveColumnLayout />
            </f:customLayout>
            <f:GridListItem class="certItems"
                            type="Active"
                            press="onPress">
                <f:layoutData>
                    <grid:ResponsiveColumnItemLayoutData columns="3" />
                </f:layoutData>
                <VBox class="sapUiSmallMargin Certifications">
                    <layoutData>
                        <FlexItemData growFactor="1"
                                      shrinkFactor="0" />
                    </layoutData>
                    <Image class="Cert_image"
                           src="{Certifications>path}" />
                </VBox>
            </f:GridListItem>
        </f:GridList>
    </Panel>
</mvc:View>